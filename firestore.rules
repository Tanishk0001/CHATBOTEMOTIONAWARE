rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerifiedOwner(userId) { 
      return isOwner(userId) && request.auth.token.email_verified == true; 
    }
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProfile(data) {
      return data.keys().hasAll(['updatedAt']) &&
             data.updatedAt is timestamp &&
             (!data.keys().contains('displayName') || data.displayName == null || (data.displayName is string && data.displayName.size() <= 200)) &&
             (!data.keys().contains('bio') || data.bio == null || (data.bio is string && data.bio.size() <= 1000)) &&
             (!data.keys().contains('neuralMemory') || (data.neuralMemory is list && data.neuralMemory.size() <= 200)) &&
             (!data.keys().contains('preferences') || (data.preferences is map));
    }

    // User Profile Partition
    match /users/{userId} {
       match /private/profile {
         allow read: if isOwner(userId);
         allow create, update: if isOwner(userId) && isValidId(userId) && isValidProfile(incoming());
         allow delete: if isOwner(userId);
       }
    }
  }
}
